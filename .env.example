# ============================================
# 基金驾驶舱 — 环境变量配置
# 复制本文件为 .env 并填入你的配置：
#   cp .env.example .env
# ============================================

# --- Flask / JWT (必填) ---
# 生成一个随机密钥：python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-string

# --- SMTP 邮箱 (可选，用于邮件验证码、每日报告、部署通知) ---
# 以 QQ 邮箱为例（需开启 SMTP 服务获取授权码）：
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-authorization-code
EMAIL_FROM=your-email@qq.com
FROM_NAME=基金驾驶舱
REPLY_TO_EMAIL=

# --- DeepSeek AI (可选，用于 AI 问答功能) ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# --- 每日收益报告 (可选) ---
DAILY_REPORT_EMAIL=
DAILY_REPORT_TIME=20:00

# --- Webhook 自动部署 (可选，仅自托管服务器需要) ---
WEBHOOK_SECRET=
PROJECT_DIR=/root/fund-cockpit
DEPLOY_NOTIFY_EMAIL=
