# ============================================
# 基金驾驶舱 — 环境变量配置
#
# 📋 使用方式：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 打开 .env 文件，把下面的值改成你自己的
#   3. 不需要的功能留空即可
# ============================================

# ──────── 必填 ────────

# JWT 签名密钥（用于用户登录认证）
# 执行以下命令生成一个随机密钥：
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# 然后把输出的字符串粘贴到下面（等号右边）：
JWT_SECRET=change-me-to-a-random-string


# ──────── 邮箱（可选）───────
# 用于：注册验证码、每日收益报告、部署通知
# 不配置不影响核心功能，只是邮件相关功能不可用
#
# 以 QQ 邮箱为例：
#   1. 登录 QQ 邮箱 → 设置 → 账户 → 开启 SMTP
#   2. 生成授权码（代替登录密码）
#   3. 填入下方对应字段
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的QQ邮箱@qq.com
SMTP_PASS=你的SMTP授权码（不是QQ密码）
EMAIL_FROM=你的QQ邮箱@qq.com

# 发件人显示名称（收件人看到的发件人名字）
FROM_NAME=基金驾驶舱

# 回复邮箱（用户回复邮件时发给谁，不填则用 EMAIL_FROM）
REPLY_TO_EMAIL=


# ──────── DeepSeek AI（可选）───────
# 用于：AI 问答功能
# 不配置则 AI 问答不可用，其他功能正常
#
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-你的DeepSeek API密钥
DEEPSEEK_MODEL=deepseek-chat


# ──────── 每日收益报告（可选）───────
# 需要先配置上方 SMTP 邮箱
DAILY_REPORT_EMAIL=接收每日报告的邮箱
DAILY_REPORT_TIME=20:00


# ──────── Webhook 自动部署（可选，仅自托管服务器需要）───────
WEBHOOK_SECRET=Webhook密钥（与Git平台配置的一致）
PROJECT_DIR=/root/fund-cockpit
DEPLOY_NOTIFY_EMAIL=部署通知接收邮箱
